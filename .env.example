# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# Your domain (DNS A/AAAA record must point at this server). Caddy gets HTTPS for it.
DOMAIN=face.example.com

# Admin console / enrolment password (or create operator accounts with manage_admins.py).
FACE_ADMIN_PASSWORD=change-me-now

# Long random strings (e.g. `openssl rand -base64 32`). Keep them secret + backed up.
FACE_SECRET_KEY=replace-with-a-long-random-string
FACE_DB_KEY=replace-with-another-long-random-secret

# Optional:
# FACE_SIGNING_SECRET=hmac-sign-first-party-verify-results
# FACE_CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com
# FACE_RATE_LIMIT=120
# FACE_RATE_WINDOW=60
